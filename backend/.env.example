# ============================================================
# Society Management System — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env — only .env.example goes into version control.
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:1234567890@localhost:5432/Society Management System

# ─── Redis (Upstash or local) ───────────────────────────────
REDIS_URL="rediss://default:gQAAAAAAAauXAAIgcDIxODQwM2Q5Y2RhOTQ0NDg4OTc3NDM5YmNmZTNjZTA1Zg@active-monkfish-109463.upstash.io:6379"
# ─── JWT Secrets (min 32 characters each) ───────────────────
JWT_ACCESS_SECRET=your_access_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── File Uploads ───────────────────────────────────────────
UPLOAD_MAX_SIZE=5242880

# ─── Cloudinary (Image Uploads) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email / SMTP (Nodemailer) ──────────────────────────────
# Leave blank to disable email dispatch (in-app notifications still work)
# For Gmail: use App Password, not your real password
# For production: use Mailgun, SendGrid, or AWS SES SMTP relay
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Society Management System <noreply@your-domain.com>

