# ============================================================
# Society Management System — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env — only .env.example goes into version control.
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:1234567890@localhost:5432/Society Management System

# ─── Redis (Upstash or local) ───────────────────────────────
REDIS_URL="rediss://default:gQAAAAAAAauXAAIgcDIxODQwM2Q5Y2RhOTQ0NDg4OTc3NDM5YmNmZTNjZTA1Zg@active-monkfish-109463.upstash.io:6379"
# ─── JWT Secrets (min 32 characters each) ───────────────────
JWT_ACCESS_SECRET=your_access_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── File Uploads ───────────────────────────────────────────
UPLOAD_MAX_SIZE=5242880
